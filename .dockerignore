# ============================================
# Jekyll 知识库 .dockerignore
# 优化以减小构建上下文和镜像大小
# ============================================

# ============================================
# 构建产物和缓存
# ============================================
_site
.jekyll-cache
.sass-cache
.jekyll-metadata
vendor/bundle
vendor/cache
vendor/gems
vendor/ruby

# ============================================
# IDE 和编辑器文件
# ============================================
.idea
.vscode
*.swp
*.swo
*~

# ============================================
# OS 文件
# ============================================
.DS_Store
Thumbs.db

# ============================================
# 日志和临时文件
# ============================================
*.log
logs
tmp
temp
*.tmp

# ============================================
# 测试文件
# ============================================
test*
_test*
spec
specs
*.test.*
*.spec.*

# ============================================
# 构建脚本和工具
# ============================================
*.py
extract_tags.py
*.sh
*.bat
build.sh

# ============================================
# Docker 配置文件 (构建时不需要)
# ============================================
Dockerfile*
docker-compose*.yml
.dockerignore

# ============================================
# CI/CD 配置
# ============================================
.github
vercel.json
.travis.yml
.circleci

# ============================================
# 构建配置
# ============================================
_config_build.yml

# ============================================
# 测试站点
# ============================================
test-site

# ============================================
# 其他
# ============================================
node_modules
.cache
dist
build

# ============================================
# 文档文件 (生产环境不需要)
# ============================================
docs/
*.md
README.md
LICENSE
CHANGELOG.md
